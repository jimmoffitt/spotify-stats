# Secrets and virtual environments
.env
.local.env
.venv/
venv/
env/

# OAuth tokens — never commit
data/spotify_tokens.json

# Personal data — large and regenerable from the GDPR export / API.
# (git does NOT support inline comments, so keep patterns on their own lines.)
# Raw GDPR export files (Streaming_History_Audio_*.json)
data/raw/
# Original downloaded/unzipped export (zip + extracted folder)
data/download/
# Cached Spotify API lookups
data/enriched/
# Processed outputs (plays.parquet, generated CSV/MD)
data/processed/
data/synced_plays.json
data/last_sync.json
# Auto-sync logs (launchd job + wrapper output)
data/*.log
# Ad-hoc review exports (e.g. kid-band exclusion candidates)
data/*.csv
# Backups of personal config (e.g. exclusions.json.bak)
data/*.bak

# User settings — personal preferences, not shared
data/settings.json
data/exclusions.json
data/groups.json

# Demo mode (data/demo/): the sanitized plays.parquet from make_demo_data.py
# IS tracked; runtime writes made while running in demo mode are not.
data/demo/settings.json
data/demo/exclusions.json
data/demo/groups.json
data/demo/last_sync.json

# Local Claude Code settings (personal, machine-specific)
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
.idea/
.vscode/
